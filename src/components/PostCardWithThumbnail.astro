---
import { formatDate } from '../utils/date';
import { optimizeImagePath } from '../utils/optimizeImagePath';
import AuthorBadge from './AuthorBadge.astro';
import { getAuthorAvatar, getAuthorHref, getAuthorName } from '../utils/authors';

interface Props {
  post: {
    id: string;
    url: string;
    frontmatter: {
      title: string;
      date: string;
      excerpt: string;
      image?: string;
      tags?: string[];
      author?: string;
    };
  };
  showExcerpt?: boolean;
  showTags?: boolean;
}

const { post, showExcerpt = true, showTags = true } = Astro.props;
const { title, date, excerpt, image, tags } = post.frontmatter;
const authorName = getAuthorName(post.frontmatter);
const authorAvatar = getAuthorAvatar(authorName);
const authorHref = getAuthorHref(authorName);

// Ensure image path is optimized
const optimizedImagePath = image ? optimizeImagePath(image) : null;
---

<article class="border-t border-gray-200 dark:border-gray-800 py-[4vh] xl:py-8" transition:name={`post-${post.id}`}>
  <div class="flex items-start gap-4 sm:gap-8">
    <div class="min-w-0 flex-1 space-y-3">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-gray-500">
        <time datetime={new Date(date).toISOString()}>
          {formatDate(date)}
        </time>
        <span aria-hidden="true">•</span>
        <AuthorBadge name={authorName} avatar={authorAvatar} href={authorHref} />
      </div>

      <h2 class="text-xl leading-snug md:text-2xl">
        <a href={post.url} class="hover:underline focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 rounded">
          {title}
        </a>
      </h2>
      
      {showExcerpt && <p class="text-gray-500 leading-relaxed">{excerpt}</p>}

      {showTags && tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2" aria-label="Tags">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="tag"
              aria-label={`View all posts tagged ${tag}`}
            >
              {tag}
            </a>
          ))}
        </div>
      )}

      <div>
        <a 
          href={post.url} 
          class="text-sm font-medium hover:underline focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 rounded px-2 py-1 inline-block"
          aria-label={`Baca catatan ${title}`}
        >
          Baca catatan <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    {optimizedImagePath && (
      <a 
        href={post.url} 
        class="block h-24 w-24 shrink-0 overflow-hidden rounded-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:h-28 sm:w-28 md:h-32 md:w-32"
        aria-label={`View ${title} article`}
      >
        <img
          src={optimizedImagePath}
          alt={`Preview image for ${title}`}
          class="w-full h-full object-cover transition-transform hover:scale-105"
          loading="lazy"
          decoding="async"
          width="128"
          height="128"
        />
      </a>
    )}
  </div>
</article>
