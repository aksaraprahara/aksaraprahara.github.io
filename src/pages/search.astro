---
import Search from 'astro-pagefind/components/Search';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Cari"
  description="Cari di semua artikel dan halaman di blog ini."
  pagefindBody={false}
>
  <div class="max-w-3xl mx-auto">
    <header class="mb-12 text-center" transition:animate="fade">
      <h1 class="text-5xl mb-4">Cari</h1>
      <p class="text-xl text-gray-500 dark:text-gray-400">
        Cari perintah, istilah, atau topik teknikal di semua artikel.
      </p>
    </header>

    <section transition:animate="fade">
      <Search
        id="site-search"
        className="pagefind-ui brook-search"
        uiOptions={{ showImages: false, showSubResults: true }}
      />
    </section>
  </div>
</BaseLayout>
