---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { formatDate } from '../../../utils/date';
import { getVisibleDailyNotes } from '../../../utils/daily-notes';

const sectionPath = '/Tercatat-Hidup-Oleh-Entitas-Tak-Terbatas';

export async function getStaticPaths() {
  const notes = getVisibleDailyNotes(await getCollection('dailyNotes'));
  const uniqueTags = [...new Set(notes.flatMap((note) => note.data.tags || []))];

  return uniqueTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      notes: notes.filter((note) => (note.data.tags || []).includes(tag)),
    },
  }));
}

const { tag, notes } = Astro.props;
const sortedNotes = getVisibleDailyNotes(notes);
---

<BaseLayout title={`Tag daily note: ${tag}`} description={`Catatan dengan tag ${tag}`} pagefindBody={false}>
  <div class="max-w-4xl mx-auto">
    <header class="mb-12 text-center">
      <h1 class="text-5xl mb-4">Tag: {tag}</h1>
      <p class="text-xl text-gray-500">{sortedNotes.length} catatan dengan tag ini</p>
    </header>

    <div class="border-b border-gray-200 dark:border-gray-800">
      {sortedNotes.map((note) => (
        <article class="border-t border-gray-200 py-5 dark:border-gray-800">
          <div class="mb-2 text-sm text-gray-500">{formatDate(note.data.date)}</div>
          <h2 class="mt-0 mb-2 text-2xl md:text-3xl">
            <a href={`${sectionPath}/${note.id}`} class="text-gray-900 hover:underline dark:text-gray-100">{note.data.title}</a>
          </h2>
          <p class="mb-3 text-gray-500">{note.data.excerpt}</p>
          <div class="mb-3 flex flex-wrap gap-2" aria-label="Daily note tags">
            {(note.data.tags || []).map((item) => (
              <a href={`${sectionPath}/tags/${item}`} class="tag">{item}</a>
            ))}
          </div>
          <a href={`${sectionPath}/${note.id}`} class="text-sm font-medium hover:underline">Baca catatan <span aria-hidden="true">→</span></a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
